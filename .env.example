# Database
DATABASE_URL=postgresql+asyncpg://ragkb:ragkb_dev@postgres:5432/ragkb
POSTGRES_DB=ragkb
POSTGRES_USER=ragkb
POSTGRES_PASSWORD=ragkb_dev

# Redis
REDIS_URL=redis://redis:6379/0

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=ollama/llama3.2
OLLAMA_API_BASE=http://ollama:11434

# Optionally use OpenAI instead:
# LLM_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Upload
UPLOAD_DIR=/app/uploads

# Rate Limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
